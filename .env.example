# Main app
VITE_APP_URL=https://exampleurl.com
VITE_APP_DOMAIN=exampleurl.com

# Firebase (Realtime Database) — leave blank for local/demo mode
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional analytics & monitoring
VITE_GA_ID=
VITE_SENTRY_DSN=

# Help routing
# In-app /help always works. External help URL is optional:
# VITE_HELP_URL=https://help.exampleurl.com
VITE_HELP_DOMAIN=help.exampleurl.com

# Help subdomain split (off by default — do not use host.startsWith blindly)
VITE_ENABLE_HELP_SUBDOMAIN=false
# When enabled, only this exact host serves HelpApp (e.g. help.uno-web.com)
# VITE_HELP_HOST=help.uno-web.com
